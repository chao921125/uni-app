	// 设置页面路径及窗口表现 style 覆盖 globalStyle
	"pages": [{
		"path": "pages/welcome",
		"style": {
			"navigationBarTitleText": "欢迎页",
			"navigationStyle": "custom"
		},
		"needLogin": false
	}, {
		"path": "pages/tabbar",
		"style": {
			"navigationBarTitleText": "首页",
			"enablePullDownRefresh": true
		},
		"needLogin": false
	}],
	"subPackages": [{
		"root": "pages-auth/",
		"pages": [{
			"path": "login",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "登录",
				"enablePullDownRefresh": true
			}
		}]
	}, {
		"root": "pages-user/",
		"pages": [{
			"path": "my",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTitleText": "个人中心",
				"enablePullDownRefresh": true
			}
		}]
	}],
	// 分包预下载规则
	"preloadRule": {
		"pages/welcome": {
			"network": "all",
			"packages": ["__APP__"]
		},
		"pages-auth/login": {
			"network": "all",
			"packages": ["pages-auth"]
		},
		"pages-user/my": {
			"network": "all",
			"packages": ["pages-user"]
		}
	},
